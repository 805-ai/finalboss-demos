    <!-- PAGE CONFIG / BINDINGS -->
    <script>
        // Configure these values before deploying.
        const AFTERBYTES_CONFIG = {
            previewUrl: "",            // e.g., "https://www.preview.com/projects/..."
            trailerEmbedUrl: "",           // e.g., "https://www.youtube.com/embed/VIDEO_ID"
            launchDateISO: "",             // e.g., "2026-02-03T09:00:00-08:00" (optional)

            raisedUSD: 3400,
            goalUSD: 100000,

            foundersCap: 500,
            foundersCommitted: 17,

            firstCustomLimit: 50
        };

        function formatUSD(n) {
            try {
                return n.toLocaleString(undefined, { style: "currency", currency: "USD", maximumFractionDigits: 0 });
            } catch {
                return "$" + String(n);
            }
        }

        function setAll(bindName, value) {
            document.querySelectorAll(`[data-bind="${bindName}"]`).forEach(el => { el.textContent = value; });
        }

        function updateCountdown() {
            const target = AFTERBYTES_CONFIG.launchDateISO ? new Date(AFTERBYTES_CONFIG.launchDateISO) : null;
            if (!target || Number.isNaN(target.getTime())) return; // leave default text in place

            const now = new Date();
            const ms = target.getTime() - now.getTime();
            const days = Math.max(0, Math.ceil(ms / (1000 * 60 * 60 * 24)));

            setAll("launchCountdown", `${days} Days Remaining`);
        }

        item.classList.toggle("locked-item", !unlocked);
                if (unlocked) {
                    item.classList.remove("border-neutral-800");
                    item.classList.add("border-red-600");
                } else {
                    item.classList.remove("border-red-600");
                    item.classList.add("border-neutral-800");
                }

                const icon = item.querySelector("i");
                if (icon) {
                    const iconWrap = icon.parentElement;
                    if (iconWrap) {
                        iconWrap.classList.toggle("text-red-600", unlocked);
                        iconWrap.classList.toggle("text-neutral-600", !unlocked);
                    }
                }

                const title = item.querySelector("h4");
                if (title) {
                    title.classList.toggle("text-white", unlocked);
                    title.classList.toggle("text-neutral-300", !unlocked);
                }

                const desc = item.querySelector("p");
                if (desc) {
                    desc.classList.toggle("text-neutral-400", unlocked);
                    desc.classList.toggle("text-neutral-500", !unlocked);
                }
            });
        }

        function wireLinks() {
            const url = AFTERBYTES_CONFIG.previewUrl;
            ["ctaBack", "ctaBack2"].forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                if (url) el.setAttribute("href", url);
                else el.setAttribute("href", "#");
            });

            const frame = document.getElementById("trailerFrame");
            if (frame && AFTERBYTES_CONFIG.trailerEmbedUrl) {
                frame.setAttribute("src", AFTERBYTES_CONFIG.trailerEmbedUrl);
            }
        }

        function init() {
            updateCountdown();
            wireLinks();
        }

        document.addEventListener("DOMContentLoaded", init);
    </script>

